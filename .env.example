# ==============================================================================
# Variables de entorno — musicstore-api-node
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────
# Puerto en el que escucha la API
PORT=3000

# ── Base de datos ─────────────────────────────────────────────────────────
# Cadena de conexión a MongoDB (usa tus credenciales de MongoDB Atlas o local)
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@cluster0.mongodb.net/musica?retryWrites=true&w=majority
